# Do not copy manually — run:  make setup
# That generates .env with a strong random Postgres password (Odoo uses it via compose).
#
# Manual copy only if you prefer your own secrets:
#   cp .env.example .env   # then edit every value

POSTGRES_USER=odoo
POSTGRES_PASSWORD=replace_me_or_run_make_setup
POSTGRES_DB=postgres

ODOO_DB_NAME=mycompany

# Backups (optional — used by make backup)
# Local dev:  BACKUP_ROOT=./backups/host
# VPS:        BACKUP_ROOT=/var/backups/odoo  (run: sudo mkdir -p /var/backups/odoo && sudo chown $USER:$USER /var/backups/odoo)
# RETENTION_DAYS=14
